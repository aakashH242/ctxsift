# CtxSift environment configuration template
# Precedence:
# CLI flags > environment variables > workspace config > global config > defaults
#
# Copy the variables you need into your real shell environment or a local .env file
# that your tooling loads before running ctxsift.

# Remote LLM base URL.
# Example: https://api.openai.com/v1
# When this is set, ctxsift uses the LiteLLM remote path for compression
# and skips the local Gemma backend entirely. If the remote call fails,
# ctxsift returns passthrough output with a warning and does not store it.
CTXSIFT_LLM_BASE_URL=

# Remote LLM API key.
# Leave empty when you want local-only operation.
CTXSIFT_LLM_API_KEY=

# Remote LLM model name used by the LiteLLM remote path.
# Example: gpt-5-mini
# Required when CTXSIFT_LLM_BASE_URL is set.
CTXSIFT_LLM_MODEL=

# Optional remote provider API version.
# Useful for providers that require an explicit version header or query parameter.
CTXSIFT_LLM_API_VERSION=

# Remote reasoning mode override.
# Allowed values: auto, true, false
CTXSIFT_LLM_REASONING_MODE=auto

# Maximum tokens to allow in compressed output.
# Default: 512
CTXSIFT_MAX_OUTPUT_TOKENS=512

# Request timeout in milliseconds for model calls and other bounded operations.
# Default: 90000
CTXSIFT_TIMEOUT_MS=90000

# Retry count for retryable remote operations.
# Default: 1
CTXSIFT_RETRIES=1

# Enable deterministic output recovery before ctxsift returns the final answer.
# Default: true
# Applies to both local and remote compression paths.
# Set to false if you want to compare behavior with and without the deterministic recovery step.
# Unsure? Keep it enabled and run a benchmark with your desired model to find whether it helps or not.
CTXSIFT_RECOVERY_ENABLED=true

# Local compression model source.
# Default CPU value: ibm-granite/granite-4.0-350m-GGUF
#
# Runtime semantics:
# - CPU local compression uses embedded llama.cpp and expects a GGUF repo id here
# - CUDA local compression uses Transformers and expects a normal Hugging Face text model id here
#
# Examples:
# - CPU: ibm-granite/granite-4.0-350m-GGUF
# - GPU: Qwen/Qwen3.5-0.8B
CTXSIFT_LOCAL_MODEL=ibm-granite/granite-4.0-350m-GGUF

# GGUF filename used only when local compression resolves to CPU llama.cpp.
# Use one concrete `.gguf` file listed under the Hugging Face repo's Files tab.
# `ctxsift configure` and first runtime use will download it automatically.
# Default: smollm2-360m-instruct-q8_0.gguf
CTXSIFT_LOCAL_GGUF_FILENAME=smollm2-360m-instruct-q8_0.gguf

# Local device preference.
# Recommended values: auto, cpu, cuda, cuda:0
# Default: auto
# In auto mode, ctxsift keeps GGUF-style CPU configs on llama.cpp and uses
# CUDA/Transformers when the configured local model is a CUDA-style model and
# a working CUDA runtime is available.
CTXSIFT_LOCAL_DEVICE=auto

# Local dtype preference passed to the Transformers pipeline.
# Only relevant when local compression resolves to CUDA/Transformers.
# Recommended values: auto, float32, float16, bfloat16
# Default: auto
CTXSIFT_LOCAL_DTYPE=auto

# Optional local attention backend override for local Transformers compression.
# Only relevant when local compression resolves to CUDA/Transformers.
# Recommended values: auto, sdpa, flash_attention_2
# Default: auto
#
# What this controls:
# - auto: let ctxsift choose the safest backend for the current runtime
# - sdpa: force PyTorch scaled-dot-product attention
# - flash_attention_2: force Flash Attention when the package and GPU support it
#
# When to use what:
# - auto: recommended default; on supported CUDA installs, ctxsift prefers
#   flash_attention_2 automatically, otherwise it falls back to the standard path
# - sdpa: use when you want the most conservative and broadly compatible behavior,
#   or when debugging Flash Attention issues
# - flash_attention_2: use when you explicitly want the faster CUDA path and know
#   the dependency stack and hardware support it
#
# Tradeoffs:
# - sdpa is usually the safest option but may be slower on long contexts
# - flash_attention_2 can reduce memory use and improve throughput on supported GPUs,
#   but it requires the extra package and may be unavailable on unsupported platforms
#
# Reference docs:
# - PyTorch SDPA: https://pytorch.org/docs/stable/generated/torch.nn.functional.scaled_dot_product_attention.html
# - Flash Attention package: https://pypi.org/project/flash-attn/
CTXSIFT_LOCAL_ATTN_IMPLEMENTATION=auto

# Optional local Transformers quantization mode.
# Only relevant when local compression resolves to CUDA/Transformers.
# Allowed values:
# - none
# - bnb-8bit
# - bnb-4bit-fp4
# - bnb-4bit-nf4
#
# Package requirements:
# - bnb-* requires `ctxsift[quant]`
# - bitsandbytes quantization also requires `accelerate`
# - support is model-dependent and can vary by hardware/runtime backend
#
# What this controls:
# - none: load the model without weight quantization
# - bnb-8bit: 8-bit BitsAndBytes quantization; best first step when VRAM is tight
# - bnb-4bit-fp4 / bnb-4bit-nf4: more aggressive 4-bit BitsAndBytes modes;
#   lower memory use, usually more quality/speed tradeoff than 8-bit
#
# When to use what:
# - none: use when you want the simplest, most predictable behavior and have enough memory
# - bnb-8bit: good default when you need a meaningful memory reduction with a smaller
#   quality risk than 4-bit modes
# - bnb-4bit-*: use when the model does not fit otherwise and you are
#   willing to trade some output quality or runtime stability for lower memory use
#
# Practical guidance:
# - this setting only affects local CUDA/Transformers compression
# - leave it at `none` unless the chosen GPU model does not fit comfortably in VRAM
# - try `bnb-8bit` before either 4-bit mode; move to 4-bit only when you still need more memory headroom
#
# Tradeoffs:
# - more aggressive quantization reduces memory use, but can reduce output quality,
#   increase compatibility risk, or limit which hardware/runtime combinations work well
# - quantized models are loaded with quantization and device placement together; if the
#   required packages are missing, ctxsift fails and warns instead of silently ignoring the setting
#
# How to research quantization support:
# - bitsandbytes docs: https://huggingface.co/docs/transformers/en/quantization/bitsandbytes
# - model hub search: look for model cards, tags, or repos that mention 8-bit, 4-bit,
#   NF4, FP4, int8, int4, int2, float8, GPTQ, AWQ, or GGUF
# - if a model repo publishes a prequantized variant, it is usually a separate repo or
#   branch with that quantization called out in the model name or card
CTXSIFT_LOCAL_QUANTIZATION=none

# Optional persisted quantized-model cache root.
# Default: empty
#
# What this does:
# - when local quantization is enabled, ctxsift can save the resulting quantized
#   checkpoint to disk and reuse it on later cold starts instead of rebuilding it
#   from the original model cache every time
#
# Path behavior:
# - set this to a directory when you want explicit control over where saved
#   quantized checkpoints live
# - ctxsift stores quantized checkpoints under: <this path>/model/files/
# - when empty, ctxsift tries to reuse the general Hugging Face / Sentence Transformers
#   cache root when one is configured, and otherwise falls back to:
#   <home>/.cache/model_quants/model/files
#
# Tradeoffs:
# - keeping this enabled improves repeated startup time for quantized local models
# - it uses extra disk space because the original model cache and the saved quantized
#   checkpoint both exist on disk
CTXSIFT_MODEL_CACHE_PATH=

# Embedding model override for recall/vector search.
# Default: microsoft/harrier-oss-v1-0.6b
#
# What this accepts:
# - a Sentence Transformers-compatible model id loadable through `SentenceTransformer(...)`
# - dense embedding / sentence-similarity / feature-extraction models are the intended fit
# - the default Harrier model is tuned for long-context retrieval and code-adjacent recall
#
# Good places to browse:
# - Sentence Transformers docs: https://www.sbert.net/docs/quickstart.html
# - Sentence Transformers model hub: https://huggingface.co/models?library=sentence-transformers&sort=downloads
# - broader embedding candidates on the Hub often appear under sentence-similarity,
#   feature-extraction, or retrieval-oriented model cards
#
# When to override:
# - keep the Harrier default when you want stronger long-context recall and are fine with a larger model
# - switch to a smaller Sentence Transformers model when startup time, RAM, or CPU speed matter more
# - choose a domain-specific embedding model only if its model card clearly matches your retrieval task
#
# Tradeoffs:
# - larger embedding models usually improve recall quality, but cost more memory and latency
# - different models produce different embedding dimensions, so changing the model can require
#   rebuilding or reinitializing vector state for a workspace
# - not every model on the Hub with "embedding" in the name is Sentence Transformers-compatible;
#   prefer models whose cards or examples show `SentenceTransformer(...)` usage
CTXSIFT_EMBEDDING_MODEL=microsoft/harrier-oss-v1-0.6b

# Embedding backend preference.
# Recommended values: auto, torch, onnx
# Default: auto
# In auto mode, ctxsift prefers ONNX for Harrier on CPU when ONNX Runtime is available.
CTXSIFT_EMBEDDING_BACKEND=auto

# Embedding device override.
# Recommended values: auto, cpu, cuda, cuda:0
# Default: auto
# In auto mode, ctxsift prefers CUDA when PyTorch sees a usable GPU and otherwise falls back to CPU.
CTXSIFT_EMBEDDING_DEVICE=auto

# Embedding dtype override.
# Default: auto
CTXSIFT_EMBEDDING_DTYPE=auto

# Optional embedding attention backend override for torch-based embeddings.
# Recommended values: auto, sdpa, flash_attention_2
# Default: auto
# In auto mode, ctxsift prefers flash_attention_2 on GPU when supported.
CTXSIFT_EMBEDDING_ATTN_IMPLEMENTATION=auto

# Embedding encode micro-batch size used inside each Sentence Transformers encode call.
# Default: 8
# This is the model-side micro-batch knob for recall embeddings.
#
# How it interacts with the daemon:
# - the embedding daemon can first coalesce multiple incoming requests into one larger
#   daemon batch, up to CTXSIFT_DAEMON_EMBEDDING_MAX_BATCH_SIZE requests
# - inside that coalesced batch, Sentence Transformers still processes texts in
#   internal chunks of this size
#
# Practical guidance:
# - raise it when you want more throughput and have CPU/GPU memory headroom
# - lower it when you see memory pressure or model load instability
# - this is separate from CTXSIFT_DAEMON_EMBEDDING_MAX_BATCH_SIZE, which controls
#   request coalescing, not the model's internal encode chunk size
CTXSIFT_EMBEDDING_BATCH_SIZE=8

# Query prompt name for embedding query encoding.
# Leave empty to let ctxsift choose model-aware behavior.
# For Harrier models, ctxsift uses this default query prompt when empty:
# Instruct: Given a coding issue, command output, or debugging question,
# retrieve prior command outputs, errors, files, and fixes that are most useful
# for resolving the current problem.\nQuery:
# Default: empty
CTXSIFT_EMBEDDING_QUERY_PROMPT_NAME=

# Custom query prompt text for embedding query encoding. Only used for Harrier-type models.
# Used when you want to override the default ctxsift recall instruction.
# Example: Instruct: Retrieve prior coding fixes relevant to this debugging issue.\nQuery:
# Default: empty
CTXSIFT_EMBEDDING_QUERY_PROMPT=

# Optional document prompt name for embedding document encoding.
# Default: empty
CTXSIFT_EMBEDDING_DOCUMENT_PROMPT_NAME=

# Maximum embedding input length.
# Default: 32768
CTXSIFT_EMBEDDING_MAX_LENGTH=32768

# Default number of recall results to display when --limit is not provided.
# Default: 10
CTXSIFT_RECALL_DEFAULT_LIMIT=10

# Number of lexical recall candidates to fetch before hybrid fusion.
# Higher values can improve recall quality at the cost of more SQLite work.
# Default: 50
CTXSIFT_RECALL_LEXICAL_CANDIDATE_LIMIT=50

# Number of vector recall candidates to fetch before hybrid fusion.
# Higher values can improve recall quality at the cost of more embedding and sqlite-vec work.
# Default: 50
CTXSIFT_RECALL_VECTOR_CANDIDATE_LIMIT=50

# Number of high-signal anchor terms appended to verbose recall queries before vector search.
# This only affects the semantic/vector query path. FTS5 lexical search still uses the raw user query.
# Set to 0 to disable vector-query anchor compaction entirely.
# Default: 3
CTXSIFT_RECALL_ANCHOR_TERM_LIMIT=3

# Maximum sqlite-vec distance allowed for vector-only recall results.
# Lower values make recall stricter and reduce irrelevant semantic matches.
# Default: 0.75
CTXSIFT_RECALL_MAX_VECTOR_DISTANCE=0.75

# Maximum age in days for persisted compressed records before background cleanup
# prunes them from the workspace database.
# Default: 30
CTXSIFT_RETENTION_MAX_AGE_DAYS=30

# Explicit database path override.
# When unset, ctxsift will use workspace-aware defaults:
# - .git/ctxsift/ctxsift.db inside Git repos
# - .ctxsift/ctxsift.db outside Git repos

# Enable or disable background daemon serving for local models.
# Default: true
# When true:
# - local compression uses a shared background daemon keyed by the effective
#   local runtime signature
# - embeddings use a shared background daemon in both local and remote compression modes
# When false:
# - ctxsift falls back to the older in-process local model path
CTXSIFT_DAEMON_ENABLED=true

# Idle timeout before a daemon unloads its model and exits.
# Default: 600
CTXSIFT_DAEMON_IDLE_TIMEOUT_SECONDS=600

# Startup timeout for auto-started daemons.
# Default: 15000
CTXSIFT_DAEMON_STARTUP_TIMEOUT_MS=15000

# Embedding daemon micro-batch window in milliseconds.
# Default: 20
CTXSIFT_DAEMON_EMBEDDING_BATCH_WINDOW_MS=20

# Maximum number of embedding requests to coalesce into one daemon batch.
# Default: 16
CTXSIFT_DAEMON_EMBEDDING_MAX_BATCH_SIZE=16
