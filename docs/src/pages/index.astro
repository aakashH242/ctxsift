    <!-- ============ THEME TOGGLE SCRIPT ============ -->
    <script>
      function trackLandingEvent(eventName, payload = {}) {
        try {
          if (window.umami && typeof window.umami.track === 'function') {
            window.umami.track(eventName, payload);
          }
        } catch {
          // Keep landing interactions functional even when analytics is unavailable.
        }
      }

      const themeToggle = document.getElementById('landing-theme-toggle');

      function applyLandingTheme(theme) {
        document.documentElement.dataset.theme = theme === 'light' ? 'light' : 'dark';
        document.documentElement.style.colorScheme = theme === 'light' ? 'light' : 'dark';
      }

      function getBrowserTheme() {
        return window.matchMedia('(prefers-color-scheme: light)').matches ? 'light' : 'dark';
      }

      if (themeToggle) {
        // Get stored theme or browser default
        const storedLandingTheme = localStorage.getItem('starlight-theme');
        const resolvedTheme = (storedLandingTheme === 'light' || storedLandingTheme === 'dark') 
          ? storedLandingTheme 
          : getBrowserTheme();
        
        // Update active button
        function updateActiveButton(theme) {
          themeToggle.querySelectorAll('.theme-toggle-btn').forEach(btn => {
            btn.classList.toggle('active', btn.dataset.theme === theme);
          });
        }
        updateActiveButton(resolvedTheme);
        applyLandingTheme(resolvedTheme);

        // Handle button clicks
        themeToggle.querySelectorAll('.theme-toggle-btn').forEach(btn => {
          btn.addEventListener('click', () => {
            const previousTheme = document.documentElement.dataset.theme === 'light' ? 'light' : 'dark';
            const nextTheme = btn.dataset.theme;
            localStorage.setItem('starlight-theme', nextTheme);
            updateActiveButton(nextTheme);
            applyLandingTheme(nextTheme);
            if (previousTheme !== nextTheme) {
              trackLandingEvent('landing_theme_switch', { from: previousTheme, to: nextTheme });
            }
          });
        });
      }

      const docsCta = document.getElementById('cta-docs');
      if (docsCta) {
        docsCta.addEventListener('click', () => {
          trackLandingEvent('landing_cta_docs_click', { placement: 'hero', cta: 'docs' });
        });
      }

      const githubCta = document.getElementById('cta-github');
      if (githubCta) {
        githubCta.addEventListener('click', () => {
          trackLandingEvent('landing_cta_github_click', { target: 'repo' });
        });
      }

      const starsCta = document.getElementById('cta-stars');
      if (starsCta) {
        starsCta.addEventListener('click', () => {
          trackLandingEvent('landing_cta_github_click', { target: 'stars' });
        });
      }

      const installSkillCta = document.getElementById('cta-install-skill');
      if (installSkillCta) {
        installSkillCta.addEventListener('click', () => {
          trackLandingEvent('landing_install_skill_download', {
            placement: 'hero',
            source: 'cta',
          });
        });
      }

      const routeEventMap = {
        'route-local-cpu': 'local_cpu',
        'route-local-gpu': 'local_gpu',
        'route-remote-provider': 'remote_provider',
      };

      Object.entries(routeEventMap).forEach(([id, route]) => {
        const routeLink = document.getElementById(id);
        if (!routeLink) {
          return;
        }
        routeLink.addEventListener('click', () => {
          trackLandingEvent('landing_route_select', { route });
        });
      });

      function inferInstallerPlatform(anchor) {
        const source = `${anchor.getAttribute('download') || ''} ${anchor.getAttribute('href') || ''}`.toLowerCase();
        if (source.includes('windows')) {
          return 'windows';
        }
        if (source.includes('mac') || source.includes('darwin')) {
          return 'macos';
        }
        return 'linux';
      }

      const installerLinks = document.querySelectorAll('#installer [data-installer-primary], #installer [data-installer-link], #installer [data-installer-skill]');
      installerLinks.forEach((link) => {
        link.addEventListener('click', () => {
          if (link.hasAttribute('data-installer-skill')) {
            trackLandingEvent('landing_install_skill_download', {
              placement: 'installer',
              source: 'installer_block',
            });
            return;
          }
          const source = link.hasAttribute('data-installer-primary') ? 'primary' : 'secondary';
          const platform = link.getAttribute('data-installer-link') || inferInstallerPlatform(link);
          trackLandingEvent('landing_installer_download', {
            platform,
            source,
            section: 'installer',
          });
        });
      });

      const navLinks = document.querySelectorAll('.landing-nav .nav-link');
      navLinks.forEach((link) => {
        const href = link.getAttribute('href') || '';
        let navTarget = '';
        if (href.includes('github.com/aakashh242/ctxsift')) {
          navTarget = 'source';
        } else if (href === '/docs/') {
          navTarget = 'docs';
        } else if (href === '/docs/guides/benchmark/') {
          navTarget = 'benchmark';
        } else if (href === '/docs/reference/cli/') {
          navTarget = 'cli';
        }

        if (!navTarget) {
          return;
        }

        link.addEventListener('click', () => {
          trackLandingEvent('landing_nav_click', { link: navTarget });
        });
      });

      document.addEventListener('click', (event) => {
        const anchor = event.target.closest('a[href]');
        if (!anchor) {
          return;
        }

        const href = anchor.getAttribute('href') || '';
        let target = '';
        if (href.includes('pypi.org/project/ctxsift')) {
          target = 'pypi';
        } else if (href.includes('huggingface.co')) {
          target = 'huggingface';
        } else if (href.includes('/benchmark-viewer.html')) {
          target = 'benchmark_viewer';
        } else if (href.includes('LICENSE.md')) {
          target = 'license';
        }

        if (!target) {
          return;
        }

        trackLandingEvent('landing_outbound_click', { target });
      });

      const scrollDepthMilestones = [25, 50, 75, 100];
      const firedDepthMilestones = new Set();

      function emitScrollDepth() {
        const documentHeight = document.documentElement.scrollHeight - window.innerHeight;
        if (documentHeight <= 0) {
          return;
        }

        const scrollPercent = Math.round((window.scrollY / documentHeight) * 100);
        scrollDepthMilestones.forEach((milestone) => {
          if (scrollPercent >= milestone && !firedDepthMilestones.has(milestone)) {
            firedDepthMilestones.add(milestone);
            trackLandingEvent('landing_scroll_depth', { percent: milestone });
          }
        });

        if (firedDepthMilestones.size === scrollDepthMilestones.length) {
          window.removeEventListener('scroll', emitScrollDepth);
        }
      }

      window.addEventListener('scroll', emitScrollDepth, { passive: true });
      emitScrollDepth();

      const sectionIds = [
        'hero',
        'why-ctxsift-exists',
        'how-it-works',
        'supported-models',
        'setup-paths',
        'installer',
      ];

      const seenSections = new Set();
      const sectionObserver = new IntersectionObserver(
        (entries) => {
          entries.forEach((entry) => {
            if (!entry.isIntersecting) {
              return;
            }

            const section = entry.target.id;
            if (seenSections.has(section)) {
              return;
            }

            seenSections.add(section);
            trackLandingEvent('landing_section_view', { section: section.replace(/-/g, '_') });
            sectionObserver.unobserve(entry.target);
          });
        },
        { threshold: 0.35 },
      );

      sectionIds.forEach((sectionId) => {
        const sectionElement = document.getElementById(sectionId);
        if (sectionElement) {
          sectionObserver.observe(sectionElement);
        }
      });
    </script>

    <!-- ============ TYPEWRITER SCRIPT ============ -->
    <script>
      const lines = [
        { kind: 'typed', text: '$ uv tool install ctxsift', type: 'cmd' },
        { kind: 'instant', text: 'Installed ctxsift 0.1.0', type: 'result' },
        { kind: 'blank' },
        { kind: 'typed', text: '$ ctxsift configure', type: 'cmd' },
        { kind: 'prompted', prompt: 'Compression mode: ', answer: 'local' },
        { kind: 'prompted', prompt: 'Local device: ', answer: 'cpu' },
        {
          kind: 'prompted',
          prompt: 'Local model repo: ',
          answer: 'ibm-granite/granite-4.0-350m-GGUF',
        },
        { kind: 'prompted', prompt: 'Save target: ', answer: 'global' },
        { kind: 'prompted', prompt: 'Install skill for: ', answer: 'codex' },
        { kind: 'instant', text: 'Updated global config at ~/.config/ctxsift/config.toml', type: 'result' },
        { kind: 'blank' },
        {
          kind: 'typed',
          text: '$ ctxsift compress --intent exact-lines "Return only failing test ids." -- pytest -q',
          type: 'cmd',
        },
        { kind: 'instant', text: 'tests/api/test_users.py::test_create_user_requires_email', type: 'result' },
        { kind: 'instant', text: 'tests/jobs/test_reconcile.py::TestReconcile::test_retries_deadlock', type: 'result' },
        { kind: 'blank' },
        { kind: 'typed', text: '$ ctxsift recall "latest failing pytest node ids"', type: 'cmd' },
        { kind: 'instant', text: 'tests/api/test_users.py::test_create_user_requires_email', type: 'result' },
        { kind: 'instant', text: 'tests/jobs/test_reconcile.py::TestReconcile::test_retries_deadlock', type: 'result' },
      ];

      const isLightTheme = document.documentElement.getAttribute('data-theme') === 'light';
      const COLOR = {
        cmd:    isLightTheme ? '#1d4ed8' : '#7dd3fc',
        out:    isLightTheme ? '#1e293b' : '#94a3b8',
        result: isLightTheme ? '#15803d' : '#86efac',
        blank:  '',
        user:   isLightTheme ? '#0f172a' : '#e2e8f0',
      };

      function escHtml(s) {
        return s.replace(/&/g, '&amp;').replace(/</g, '&lt;').replace(/>/g, '&gt;');
      }

      function renderLine(line) {
        if (line.kind === 'blank') {
          return '\n';
        }
        if (line.kind === 'prompted') {
          return (
            `<span style="color:${COLOR.out}">${escHtml(line.prompt)}</span>` +
            `<span style="color:${COLOR.user}">${escHtml(line.answer)}</span>\n`
          );
        }
        const color = COLOR[line.type] || '#e2e8f0';
        return `<span style="color:${color}">${escHtml(line.text)}</span>\n`;
      }

      const pre = document.getElementById('terminal-output');
      if (!pre) throw new Error('terminal-output not found');

      const noMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

      if (noMotion) {
        pre.innerHTML = lines.map(renderLine).join('');
      } else {
        let lineIdx = 0;
        let charIdx = 0;
        let content = '';
        const CHAR_DELAY = 28;
        const LINE_PAUSE = 130;
        const INSTANT_PAUSE = 55;

        function renderCompletedThrough(indexExclusive) {
          return lines.slice(0, indexExclusive).map(renderLine).join('');
        }

        function typeNextStep() {
          if (lineIdx >= lines.length) {
            pre.innerHTML = content + '<span class="terminal-cursor">|</span>';
            return;
          }

          const line = lines[lineIdx];
          if (line.kind === 'blank') {
            content += '\n';
            lineIdx++;
            charIdx = 0;
            setTimeout(typeNextStep, LINE_PAUSE);
            return;
          }

          if (line.kind === 'instant') {
            content += renderLine(line);
            pre.innerHTML = content + '<span class="terminal-cursor">|</span>';
            lineIdx++;
            charIdx = 0;
            setTimeout(typeNextStep, INSTANT_PAUSE);
            return;
          }

          if (line.kind === 'typed') {
            const color = COLOR[line.type] || '#e2e8f0';
            if (charIdx < line.text.length) {
              const partial =
                `<span style="color:${color}">${escHtml(line.text.slice(0, charIdx + 1))}</span>`;
              pre.innerHTML = renderCompletedThrough(lineIdx) + partial + '<span class="terminal-cursor">|</span>';
              charIdx++;
              setTimeout(typeNextStep, CHAR_DELAY);
              return;
            }
            content += renderLine(line);
            lineIdx++;
            charIdx = 0;
            setTimeout(typeNextStep, LINE_PAUSE);
            return;
          }

          if (line.kind === 'prompted') {
            const promptHtml = `<span style="color:${COLOR.out}">${escHtml(line.prompt)}</span>`;
            if (charIdx < line.answer.length) {
              const answerHtml =
                `<span style="color:${COLOR.user}">${escHtml(line.answer.slice(0, charIdx + 1))}</span>`;
              pre.innerHTML = renderCompletedThrough(lineIdx) + promptHtml + answerHtml + '<span class="terminal-cursor">|</span>';
              charIdx++;
              setTimeout(typeNextStep, CHAR_DELAY);
              return;
            }
            content += renderLine(line);
            lineIdx++;
            charIdx = 0;
            setTimeout(typeNextStep, LINE_PAUSE);
          }
        }

        setTimeout(typeNextStep, 600);
      }
    </script>
  </body>
