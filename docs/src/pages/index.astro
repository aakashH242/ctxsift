---
import '../styles/global.css';
import '../styles/landing.css';
import CompressionShowcaseSection from '../components/CompressionShowcaseSection.astro';
import InstallerDownloads from '../components/InstallerDownloads.astro';
import { compressionShowcases } from '../data/compression-showcases';
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <script is:inline>
      (() => {
        const preferredTheme = window.matchMedia('(prefers-color-scheme: light)').matches ? 'light' : 'dark';
        const storedTheme = typeof localStorage !== 'undefined' ? localStorage.getItem('starlight-theme') : null;
        const configuredTheme = !storedTheme || storedTheme === 'auto' ? preferredTheme : storedTheme;
        const resolvedTheme = configuredTheme === 'light' ? 'light' : 'dark';
        document.documentElement.dataset.theme = resolvedTheme;
        document.documentElement.style.colorScheme = resolvedTheme;
      })();
    </script>
    <link rel="icon" href="/favicon.svg?v=2" type="image/svg+xml" />
    <link rel="icon" href="/favicon.png?v=2" type="image/png" sizes="512x512" />
    <link rel="apple-touch-icon" href="/apple-touch-icon.png?v=2" />
    <title>Save tokens and extend your coding sessions | CtxSift</title>
    <meta
      name="description"
      content="CtxSift compresses raw command outputs into recallable working memory for coding agents."
    />
    <script defer src="https://umami.tabmate.org/script.js" data-website-id="02598b51-968c-46ac-8323-f21035b348b9"></script>
    <script defer src="https://umami.tabmate.org/recorder.js" data-website-id="02598b51-968c-46ac-8323-f21035b348b9" data-sample-rate="0.4" data-mask-level="moderate" data-max-duration="300000"></script>
  </head>
